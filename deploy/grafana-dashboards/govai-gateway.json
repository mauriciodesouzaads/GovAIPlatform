{
  "annotations": { "list": [] },
  "description": "GovAI GRC Platform — Gateway Overview (FASE 10)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (by status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(govai_http_requests_total[1m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Gateway Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(govai_gateway_latency_ms_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(govai_gateway_latency_ms_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(govai_gateway_latency_ms_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "DLP Detections Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(govai_dlp_detections_total[5m])", "legendFormat": "DLP detections/sec" }
      ]
    },
    {
      "title": "Policy Violations Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        { "expr": "rate(govai_http_requests_total{status=\"blocked\"}[5m])", "legendFormat": "Blocked/sec" }
      ]
    },
    {
      "title": "Quota Exceeded Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "rate(govai_quota_exceeded_total[5m])", "legendFormat": "Quota exceeded/sec" }
      ]
    },
    {
      "title": "Active PostgreSQL Connections",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "targets": [
        { "expr": "govai_active_pg_connections", "legendFormat": "Active" }
      ]
    },
    {
      "title": "Node.js Memory (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "targets": [
        { "expr": "govai_node_process_resident_memory_bytes / 1024 / 1024", "legendFormat": "RSS (MB)" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["govai", "gateway", "observability"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GovAI — Gateway Overview",
  "uid": "govai-gateway-overview"
}
