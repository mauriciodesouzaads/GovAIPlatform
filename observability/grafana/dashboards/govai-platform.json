{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "GovAI Platform — AI Governance, Security & Observability",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Throughput & Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
          "expr": "rate(govai_http_requests_total{status=\"success\"}[2m])",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
          "expr": "rate(govai_http_requests_total{status=\"blocked\"}[2m])",
          "legendFormat": "Blocked (Policy)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
          "expr": "rate(govai_http_requests_total{status=\"approved\"}[2m])",
          "legendFormat": "Approved (HITL)",
          "refId": "C"
        }
      ],
      "title": "Request Rate by Outcome",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
          "expr": "histogram_quantile(0.50, rate(govai_gateway_latency_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
          "expr": "histogram_quantile(0.95, rate(govai_gateway_latency_ms_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
          "expr": "histogram_quantile(0.99, rate(govai_gateway_latency_ms_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Gateway Latency Percentiles (ms)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Security & Governance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
