          "refId": "B"
        }
      ],
      "title": "DLP Detections & Quota Violations",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Blocked Rate" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "govai-prometheus" },
          "expr": "sum(rate(govai_http_requests_total{status=\"blocked\"}[5m])) / sum(rate(govai_http_requests_total[5m])) * 100",
          "legendFormat": "Blocked Rate",
          "refId": "A"
        }
      ],
      "title": "Policy Block Rate (%)",
      "type": "stat"
    },
    {
