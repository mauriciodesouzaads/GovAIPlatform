# ============================================================================
# GovAI Platform — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git.
# ============================================================================

# --- AI / LLM ---
GEMINI_API_KEY=your-gemini-api-key-here
AI_MODEL=gemini/gemini-1.5-flash
LITELLM_KEY=your-litellm-proxy-key

# --- Database ---
DB_PASSWORD=generate-a-strong-password-here

# --- Security (generate with: openssl rand -hex 32) ---
SIGNING_SECRET=generate-64-char-hex-with-openssl-rand-hex-32
JWT_SECRET=generate-64-char-hex-with-openssl-rand-hex-32

# --- Notifications (optional) ---
# WEBHOOK_URL=https://your-webhook-endpoint.com/govai
# SENDGRID_API_KEY=your-sendgrid-key
# NOTIFICATION_EMAIL=admin@yourcompany.com
# SENDGRID_FROM=govai@yourcompany.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Server ---
# PORT=3000
# LOG_LEVEL=info
# ADMIN_UI_ORIGIN=https://admin.yourcompany.com
