# ============================================================================
# GovAI Platform — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git.
# ============================================================================

# --- AI / LLM ---
GEMINI_API_KEY=your-gemini-api-key-here
AI_MODEL=gemini/gemini-1.5-flash
LITELLM_KEY=your-litellm-proxy-key

# --- Database ---
DB_PASSWORD=generate-a-strong-password-here

# --- Security (generate with: openssl rand -hex 32) ---
SIGNING_SECRET=generate-64-char-hex-with-openssl-rand-hex-32
JWT_SECRET=generate-64-char-hex-with-openssl-rand-hex-32

# --- Notifications (optional) ---
# WEBHOOK_URL=https://your-webhook-endpoint.com/govai
# SENDGRID_API_KEY=your-sendgrid-key
# NOTIFICATION_EMAIL=admin@yourcompany.com
# SENDGRID_FROM=govai@yourcompany.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Server ---
# PORT=3000
# LOG_LEVEL=info
# ADMIN_UI_ORIGIN=https://admin.yourcompany.com

# --- Langfuse Observability (Delegated Telemetry) ---
LANGFUSE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key

# --- Presidio NLP (Tier 2 Semantic DLP) ---
PRESIDIO_URL=http://presidio:5001

# --- SSO / OIDC (Microsoft Entra ID or Okta) ---
OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
OIDC_CLIENT_ID=your-entra-id-app-client-id
OIDC_CLIENT_SECRET=your-entra-id-client-secret
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# --- BYOK Encryption (Org Master Key) ---
# ORG_MASTER_KEY=32-char-key-for-aes-256-gcm-byok

DB_APP_PASSWORD=generate-a-strong-password-here
