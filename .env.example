# GovAI Platform — Environment Variables
# Copy this file to .env and configure your values

# Google Gemini API Key (required for AI and embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# AI Model for LiteLLM proxy
AI_MODEL=gemini/gemini-1.5-flash

# PostgreSQL password
DB_PASSWORD=senha_forte_postgres

# LiteLLM internal proxy key
LITELLM_KEY=sk-chave-interna-proxy

# Secret for HMAC-SHA256 audit log signatures
SIGNING_SECRET=chave_mestra_para_assinar_logs_de_auditoria

# JWT Secret for admin authentication
JWT_SECRET=your_jwt_secret_here

# Admin credentials (change in production!)
ADMIN_EMAIL=admin@govai.com
ADMIN_PASSWORD=admin

# CORS: Allowed origin for admin UI (production)
# ADMIN_UI_ORIGIN=https://admin.yourdomain.com

# Log level (debug, info, warn, error)
# LOG_LEVEL=info
